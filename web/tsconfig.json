{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@wolfchow/types": ["packages/types/src/index.ts"],
      "@wolfchow/utils": ["packages/utils/src/index.ts"],
      "@wolfchow/api-client": ["packages/api-client/src/index.ts"],
      "@wolfchow/ui": ["packages/ui/src/index.ts"],
      "@wolfchow/auth": ["packages/auth/src/index.ts"]
    }
  },
  "include": ["packages/*/src", "apps/*/src", "vitest.config.ts", "vitest.setup.ts"],
  "exclude": ["node_modules", "**/dist"]
}

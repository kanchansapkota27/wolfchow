VITE_SUPERADMIN_URL=http://localhost:5173
# Widget embed script used by the Integrations page's live preview and the
# copy-paste embed snippet. Defaults to the production CDN if unset — point
# this at a locally-built web/apps/widget/dist/embed.js (served by any static
# server) to preview local widget changes from the admin app.
VITE_WIDGET_EMBED_URL=https://cdn.restroapi.com/widget.js

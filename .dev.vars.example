# Copy to .dev.vars for local development (gitignored).
# Vars (also settable in wrangler.toml [vars]); secrets must live here locally
# and be set in production via `wrangler secret put <NAME>`.

SUPABASE_URL="http://127.0.0.1:54321"
SUPABASE_ANON_KEY="your-local-supabase-anon-key"

# --- R2 image uploads (production: wrangler secret put) ---
# Account ID: Cloudflare dashboard → right sidebar → Account ID
R2_ACCOUNT_ID="your-cloudflare-account-id"
# Bucket name must match the bucket created in Cloudflare R2 dashboard
R2_BUCKET_NAME="restroapi-media"
# R2 API token: dashboard → R2 → Manage R2 API tokens → Create token (Object Read & Write)
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# --- Secrets (production: wrangler secret put) ---
SUPABASE_SERVICE_ROLE_KEY="your-local-supabase-service-role-key"
SUPABASE_JWT_SECRET="your-local-supabase-jwt-secret"
MASTER_ENCRYPTION_KEY="32-byte-base64-key-for-aes-gcm"
INTERNAL_CRON_SECRET="shared-secret-for-internal-endpoints"
# Reserved, unused (no Stripe webhooks in this architecture)
STRIPE_WEBHOOK_SECRET=""

# LOCAL DEV ONLY — controls the superadmin TOTP/MFA check.
#   "true"  = MFA check is SKIPPED  (use for local dev until MFA enroll UI is built)
#   "false" = MFA check is ENFORCED (must have TOTP in JWT amr)
# NEVER set this in production (never add to wrangler.toml or `wrangler secret put`).
MFA_DEV_BYPASS="true"

# Browser origins allowed to call the API (CORS), comma-separated. Unset = local
# Vite dev ports (5173–5177). In production set the apps' Pages origins.
# CORS_ALLOWED_ORIGINS="https://superadmin.example.com,https://admin.example.com"

# Base URL of the admin signup page used in generated invite links. Defaults to
# the production admin origin; point at the local admin app during dev.
# SIGNUP_BASE_URL="http://localhost:5174/signup"
